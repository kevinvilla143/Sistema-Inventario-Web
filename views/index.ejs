<!DOCTYPE html>
<html>
<head>
  <title>Inventario</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="container py-4">
  <div class="d-flex justify-content-between mb-3">
    <h2>Bienvenido, <%= usuario %></h2>
    <a href="/logout" class="btn btn-danger">Cerrar sesión</a>
  </div>

  <div class="card p-3 mb-4">
    <form action="/agregar" method="POST" class="row g-2">
      <div class="col-md-3"><input name="nombre" class="form-control" placeholder="Nombre" required></div>
      <div class="col-md-2"><input name="precio" type="number" class="form-control" placeholder="Precio" required></div>
      <div class="col-md-2"><input name="stock" type="number" class="form-control" placeholder="Stock" required></div>
      <div class="col-md-2"><input name="stock_minimo" type="number" class="form-control" placeholder="Stock Mínimo" required></div>
      <div class="col-md-3"><button class="btn btn-primary w-100">Agregar</button></div>
    </form>
  </div>

  <table class="table table-hover">
    <thead class="table-dark">
      <tr>
        <th>Nombre</th>
        <th>Precio</th>
        <th>Stock</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% productos.forEach(p => { %>
        <tr>
          <td><%= p.nombre %></td>
          <td>$<%= p.precio %></td>
          <td>
            <%= p.stock %>
            <% if (p.stock <= p.stock_minimo) { %>
              <span class="badge bg-danger">Stock Bajo</span>
            <% } %>
          </td>
          <td>
            <a href="/stock/<%= p.id %>/sumar" class="btn btn-success btn-sm">+</a>
            <a href="/stock/<%= p.id %>/restar" class="btn btn-warning btn-sm">-</a>
            <a href="/eliminar/<%= p.id %>" class="btn btn-danger btn-sm">Eliminar</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

</body>
</html>

