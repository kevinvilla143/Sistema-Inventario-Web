<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inventario</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <canvas id="stars"></canvas>
  <!-- NAVBAR -->
  <nav class="inv-navbar">
    <div class="brand-text">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M7 8h10M7 12h6"/></svg>
      Inventario
    </div>
    <div class="d-flex align-items-center gap-3">
      <div class="user-chip">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        <strong><%= usuario %></strong>
      </div>
      <a href="/logout" class="btn btn-danger btn-sm">Cerrar sesión</a>
    </div>
  </nav>

  <!-- CONTENIDO PRINCIPAL -->
  <div class="inv-container">

    <!-- TÍTULO -->
    <div class="inv-title-row">
      <h2>
        <small>Panel de control</small>
        Inventario
      </h2>
    </div>

    <!-- FORMULARIO AGREGAR -->
    <div class="form-card">
      <p class="form-label-hint">Agregar nuevo producto</p>
      <form action="/agregar" method="POST" class="row g-2">
        <div class="col-md-3">
          <input name="nombre" class="form-control" placeholder="Nombre" required>
        </div>
        <div class="col-md-2">
          <input name="precio" type="number" class="form-control" placeholder="Precio" required>
        </div>
        <div class="col-md-2">
          <input name="stock" type="number" class="form-control" placeholder="Stock" required>
        </div>
        <div class="col-md-2">
          <input name="stock_minimo" type="number" class="form-control" placeholder="Stock Mínimo" required>
        </div>
        <div class="col-md-3">
          <button class="btn btn-primary w-100">+ Agregar</button>
        </div>
      </form>
    </div>

    <!-- TABLA -->
    <div class="table-wrapper">
      <table class="table table-hover">
        <thead class="table-dark">
          <tr>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% productos.forEach(p => { %>
            <tr>
              <td><%= p.nombre %></td>
              <td>$<%= p.precio %></td>
              <td>
                <%= p.stock %>
                <% if (p.stock <= p.stock_minimo) { %>
                  <span class="badge bg-danger">Stock Bajo</span>
                <% } %>
              </td>
              <td>
                <a href="/stock/<%= p.id %>/sumar" class="btn btn-success btn-sm">+</a>
                <a href="/stock/<%= p.id %>/restar" class="btn btn-warning btn-sm">−</a>
                <a href="/eliminar/<%= p.id %>" class="btn btn-danger btn-sm">Eliminar</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </div>
<script>
window.onload = function(){

const canvas = document.getElementById("stars");
const ctx = canvas.getContext("2d");

canvas.width = window.innerWidth;
canvas.height = window.innerHeight;

let stars = [];

for(let i = 0; i < 120; i++){
  stars.push({
    x: Math.random() * canvas.width,
    y: Math.random() * canvas.height,
    size: Math.random() * 2,
    speed: Math.random() * 0.5
  });
}

function draw(){
  ctx.clearRect(0,0,canvas.width,canvas.height);

  ctx.fillStyle = "white";

  stars.forEach(star => {
    ctx.beginPath();
    ctx.arc(star.x, star.y, star.size, 0, Math.PI*2);
    ctx.fill();

    star.y += star.speed;

    if(star.y > canvas.height){
      star.y = 0;
      star.x = Math.random() * canvas.width;
    }
  });

  requestAnimationFrame(draw);
}

draw();

}
</script>
</body>
</html>

